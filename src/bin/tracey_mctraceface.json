        },
        {
          "kind": "option",
          "names": [
            "trace-scope"
          ],
          "doc": [
            "What to trace: userspace, kernel, or both."
          ],
          "type": "enum",
          "choices": [
            "userspace",
            "kernel",
            "both"
          ],
          "default": "userspace"
        },
        {
          "kind": "option",
          "names": [
            "timer-resolution"
          ],
          "doc": [
            "Timer resolution: low, normal, or high."
          ],
          "type": "enum",
          "choices": [
            "low",
            "normal",
            "high"
          ],
          "default": "normal"
        },
        {
          "kind": "option",
          "names": [
            "start-symbol"
          ],
          "doc": [
            "Begin recording when this symbol appears in the trace."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "option",
          "names": [
            "end-symbol"
          ],
          "doc": [
            "Stop recording when this symbol appears in the trace."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "flag",
          "names": [
            "multi-slice"
          ],
          "doc": [
            "Collect multiple start-to-end regions for comparison."
          ]
        },
        {
          "kind": "flag",
          "names": [
            "no-decode"
          ],
          "doc": [
            "Skip decoding after recording. Print the perf.data path for later decode."
          ]
        }
      ]
    },
    {
      "name": "decode",
      "doc": [
        "Decode an existing perf.data file into a trace."
      ],
      "args": [
        {
          "kind": "flag",
          "names": [
            "verbose",
            "v"
          ],
          "doc": [
            "Print perf command and other diagnostic information."
          ]
        },
        {
          "kind": "option",
          "names": [
            "working-directory",
            "d"
          ],
          "doc": [
            "Directory containing perf.data."
          ],
          "type": "dir",
          "required": true,
          "docv": "DIR"
        },
        {
          "kind": "option",
          "names": [
            "executable",
            "e"
          ],
          "doc": [
            "ELF binary for symbol resolution."
          ],
          "type": "file",
          "docv": "FILE"
        },
        {
          "kind": "option",
          "names": [
            "output",
            "o"
          ],
          "doc": [
            "Output trace file path."
          ],
          "type": "string",
          "default": "trace.fxt",
          "docv": "FILE"
        },
        {
