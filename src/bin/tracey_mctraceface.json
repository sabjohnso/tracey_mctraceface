            "o"
          ],
          "doc": [
            "Output trace file path."
          ],
          "type": "string",
          "default": "trace.fxt",
          "docv": "FILE"
        },
        {
          "kind": "flag",
          "names": [
            "serve"
          ],
          "doc": [
            "Open the trace in Perfetto UI via a local HTTP server."
          ]
        },
        {
          "kind": "option",
          "names": [
            "serve-port"
          ],
          "doc": [
            "Port for the local trace server."
          ],
          "type": "int",
          "default": 8080,
          "docv": "PORT"
        },
        {
          "kind": "option",
          "names": [
            "trigger",
            "t"
          ],
          "doc": [
            "Symbol to trigger snapshot on."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "flag",
          "names": [
            "multi-snapshot"
          ],
          "doc": [
