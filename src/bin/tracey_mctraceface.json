{
  "name": "tracey_mctraceface",
  "doc": [
    "Intel Processor Trace recorder and decoder.",
    "Captures and reconstructs call stacks from hardware traces."
  ],
  "version": "0.1.0",
  "commands": [
    {
      "name": "run",
      "doc": ["Launch a program under trace and capture its execution."],
      "args": [
        {
          "kind": "flag",
          "names": ["multi-thread"],
          "doc": ["Trace all threads, not just the main thread."]
        },
        {
          "kind": "flag",
          "names": ["full-execution"],
          "doc": ["Record entire execution, not a snapshot ring buffer."]
        },
        {
          "kind": "flag",
          "names": ["sampling"],
          "doc": ["Use stacktrace sampling instead of Intel PT."]
        },
        {
          "kind": "option",
          "names": ["output", "o"],
          "doc": ["Output trace file path."],
          "type": "string",
          "default": "trace.fxt",
          "docv": "FILE"
        },
        {
          "kind": "option",
          "names": ["trigger", "t"],
          "doc": ["Symbol to trigger snapshot on."],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "flag",
          "names": ["multi-snapshot"],
          "doc": ["Take repeated snapshots on each trigger hit."]
        },
        {
          "kind": "option",
          "names": ["snapshot-size"],
          "doc": ["Ring buffer size in pages (power of 2)."],
          "type": "int",
          "docv": "PAGES"
        },
        {
          "kind": "option",
          "names": ["trace-scope"],
          "doc": ["What to trace: userspace, kernel, or both."],
          "type": "enum",
          "choices": ["userspace", "kernel", "both"],
          "default": "userspace"
        },
        {
          "kind": "option",
          "names": ["timer-resolution"],
          "doc": ["Timer resolution: low, normal, or high."],
          "type": "enum",
          "choices": ["low", "normal", "high"],
          "default": "normal"
        },
        {
          "kind": "positional",
          "name": "program",
          "doc": ["Program to run."],
          "type": "string",
          "required": true,
          "docv": "PROGRAM"
        },
        {
          "kind": "positional",
          "name": "args",
          "doc": ["Arguments to pass to the program."],
          "type": "string",
          "repeated": true,
          "docv": "ARGS"
        }
      ]
    },
    {
      "name": "attach",
      "doc": ["Attach to a running process and trace it."],
      "args": [
        {
          "kind": "option",
          "names": ["pid", "p"],
          "doc": ["Process ID(s) to attach to (comma-separated)."],
          "type": "string",
          "required": true,
          "docv": "PID"
        },
        {
          "kind": "flag",
          "names": ["multi-thread"],
          "doc": ["Trace all threads, not just the main thread."]
        },
        {
          "kind": "flag",
          "names": ["full-execution"],
          "doc": ["Record entire execution, not a snapshot ring buffer."]
        },
        {
          "kind": "flag",
          "names": ["sampling"],
          "doc": ["Use stacktrace sampling instead of Intel PT."]
        },
        {
          "kind": "option",
          "names": ["output", "o"],
          "doc": ["Output trace file path."],
          "type": "string",
          "default": "trace.fxt",
          "docv": "FILE"
        },
        {
          "kind": "option",
          "names": ["trigger", "t"],
          "doc": ["Symbol to trigger snapshot on."],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "flag",
          "names": ["multi-snapshot"],
          "doc": ["Take repeated snapshots on each trigger hit."]
        },
        {
          "kind": "option",
          "names": ["snapshot-size"],
          "doc": ["Ring buffer size in pages (power of 2)."],
          "type": "int",
          "docv": "PAGES"
        },
        {
          "kind": "option",
          "names": ["trace-scope"],
          "doc": ["What to trace: userspace, kernel, or both."],
          "type": "enum",
          "choices": ["userspace", "kernel", "both"],
          "default": "userspace"
        },
        {
          "kind": "option",
          "names": ["timer-resolution"],
          "doc": ["Timer resolution: low, normal, or high."],
          "type": "enum",
          "choices": ["low", "normal", "high"],
          "default": "normal"
        }
      ]
    },
    {
      "name": "decode",
      "doc": ["Decode an existing perf.data file into a trace."],
      "args": [
        {
          "kind": "option",
          "names": ["working-directory", "d"],
          "doc": ["Directory containing perf.data."],
          "type": "dir",
          "required": true,
          "docv": "DIR"
        },
        {
          "kind": "option",
          "names": ["executable", "e"],
          "doc": ["ELF binary for symbol resolution."],
          "type": "file",
          "docv": "FILE"
        },
        {
          "kind": "option",
          "names": ["output", "o"],
          "doc": ["Output trace file path."],
          "type": "string",
          "default": "trace.fxt",
          "docv": "FILE"
        },
        {
          "kind": "flag",
          "names": ["sampling"],
          "doc": ["Decode as sampling data instead of Intel PT."]
        }
      ]
    }
  ]
}
