{
  "name": "tracey_mctraceface",
  "doc": [
    "Intel Processor Trace recorder and decoder.",
    "Captures and reconstructs call stacks from hardware traces."
  ],
  "version": "0.1.0",
  "commands": [
    {
      "name": "run",
      "doc": [
        "Launch a program under trace and capture its execution."
      ],
      "args": [
        {
          "kind": "flag",
          "names": [
            "verbose",
            "v"
          ],
          "doc": [
            "Print perf command and other diagnostic information."
          ]
        },
        {
          "kind": "flag",
          "names": [
            "multi-thread"
          ],
          "doc": [
            "Trace all threads, not just the main thread."
          ]
        },
        {
          "kind": "flag",
          "names": [
            "full-execution"
          ],
          "doc": [
            "Record entire execution, not a snapshot ring buffer."
          ]
        },
        {
          "kind": "flag",
          "names": [
            "sampling"
          ],
          "doc": [
            "Use stacktrace sampling instead of Intel PT."
          ]
        },
        {
          "kind": "option",
          "names": [
            "output",
            "o"
          ],
          "doc": [
            "Output trace file path."
          ],
          "type": "string",
          "default": "trace.fxt",
          "docv": "FILE"
        },
        {
          "kind": "flag",
          "names": [
            "serve"
          ],
          "doc": [
            "Open the trace in Perfetto UI via a local HTTP server."
          ]
        },
        {
          "kind": "option",
          "names": [
            "serve-port"
          ],
          "doc": [
            "Port for the local trace server."
          ],
          "type": "int",
          "default": 8080,
          "docv": "PORT"
        },
        {
          "kind": "option",
          "names": [
            "trigger",
            "t"
          ],
          "doc": [
            "Symbol to trigger snapshot on."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "flag",
          "names": [
            "multi-snapshot"
          ],
          "doc": [
            "Take repeated snapshots on each trigger hit."
          ]
        },
        {
          "kind": "option",
          "names": [
            "snapshot-size"
          ],
          "doc": [
            "Ring buffer size in pages (power of 2)."
          ],
          "type": "int",
          "docv": "PAGES"
        },
        {
          "kind": "option",
          "names": [
            "trace-scope"
          ],
          "doc": [
            "What to trace: userspace, kernel, or both."
          ],
          "type": "enum",
          "choices": [
            "userspace",
            "kernel",
            "both"
          ],
          "default": "userspace"
        },
        {
          "kind": "option",
          "names": [
            "timer-resolution"
          ],
          "doc": [
            "Timer resolution: low, normal, or high."
          ],
          "type": "enum",
          "choices": [
            "low",
            "normal",
            "high"
          ],
          "default": "normal"
        },
        {
          "kind": "option",
          "names": [
            "start-symbol"
          ],
          "doc": [
            "Begin recording when this symbol appears in the trace."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "option",
          "names": [
            "end-symbol"
          ],
          "doc": [
            "Stop recording when this symbol appears in the trace."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "flag",
          "names": [
            "multi-slice"
          ],
          "doc": [
            "Collect multiple start-to-end regions for comparison."
          ]
        },
        {
          "kind": "flag",
          "names": [
            "no-decode"
          ],
          "doc": [
            "Skip decoding after recording. Print the perf.data path for later decode."
          ]
        },
        {
          "kind": "positional",
          "name": "program",
          "doc": [
            "Program to run."
          ],
          "type": "string",
          "required": true,
          "docv": "PROGRAM"
        },
        {
          "kind": "positional",
          "name": "args",
          "doc": [
            "Arguments to pass to the program."
          ],
          "type": "string",
          "repeated": true,
          "docv": "ARGS"
        }
      ]
    },
    {
      "name": "attach",
      "doc": [
        "Attach to a running process and trace it."
      ],
      "args": [
        {
          "kind": "flag",
