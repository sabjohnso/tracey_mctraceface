            "serve"
          ],
          "doc": [
            "Open the trace in Perfetto UI via a local HTTP server."
          ]
        },
        {
          "kind": "option",
          "names": [
            "serve-port"
          ],
          "doc": [
            "Port for the local trace server."
          ],
          "type": "int",
          "default": 8080,
          "docv": "PORT"
        },
        {
          "kind": "flag",
          "names": [
            "sampling"
          ],
          "doc": [
            "Decode as sampling data instead of Intel PT."
          ]
        },
        {
          "kind": "option",
          "names": [
            "start-symbol"
          ],
          "doc": [
            "Begin recording when this symbol appears in the trace."
          ],
          "type": "string",
          "docv": "SYMBOL"
        },
        {
          "kind": "option",
          "names": [
            "end-symbol"
          ],
          "doc": [
